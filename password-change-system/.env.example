# ============================================
# Environment Configuration
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/password_change_db?retryWrites=true&w=majority
MONGODB_DB_NAME=password_change_db

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration (HS256 - Simple Starter Profile)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_256_bit_secret_key_here_minimum_32_bytes_long
JWT_EXPIRES_IN=7d

# Bcrypt Configuration
# Auto-calibrated at startup to ~250ms, fallback to this value
BCRYPT_COST=12

# Rate Limiting
RATE_LIMIT_IP_WINDOW_MS=900000
RATE_LIMIT_IP_MAX=5
RATE_LIMIT_USER_WINDOW_MS=3600000
RATE_LIMIT_USER_MAX=3

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App Name

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Security
TRUST_PROXY=false
